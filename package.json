{
	"name": "add-function-return-types",
	"version": "3.7.0",
	"description": "A CLI tool to add explicit return types to TypeScript functions",
	"keywords": [
		"cli",
		"explicit-function-return-type",
		"return",
		"tool",
		"types",
		"typescript"
	],
	"homepage": "https://github.com/brandhaug/add-function-return-types#readme",
	"bugs": {
		"url": "https://github.com/brandhaug/add-function-return-types/issues"
	},
	"license": "MIT",
	"author": "Martin Brandhaug",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/brandhaug/add-function-return-types.git"
	},
	"bin": {
		"add-function-return-types": "dist/bin.js"
	},
	"files": [
		"dist/"
	],
	"type": "module",
	"main": "./dist/index.js",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsc",
		"start": "node dist/index.js",
		"lint": "oxlint --type-aware",
		"format": "oxfmt --write",
		"format:check": "oxfmt --check",
		"typecheck": "oxlint --type-aware",
		"prepare": "git config core.hooksPath .githooks",
		"test": "vitest",
		"validate": "npm run lint && npm run typecheck && npm run test"
	},
	"dependencies": {
		"commander": "14.0.0",
		"fast-glob": "3.3.3",
		"ts-morph": "26.0.0"
	},
	"devDependencies": {
		"@types/node": "25.5.2",
		"execa": "9.6.0",
		"oxfmt": "0.44.0",
		"oxlint": "1.59.0",
		"oxlint-tsgolint": "0.20.0",
		"tsx": "4.20.3",
		"typescript": "5.9.2",
		"vitest": "3.2.4"
	},
	"engines": {
		"node": ">=20"
	}
}
